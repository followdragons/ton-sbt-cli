MNEMONIC=word1 word2 word3 word4 word5 word6 word7 word8 word9 word10 word11 word12 word13 word14 word15 word16 word17 word18 word19 word20 word21 word22 word23 word24
# Use the mnemonic of an existing owner wallet or a wallet created with `wallet-new`.
WALLET_VERSION=v5r1
# Set `v5r1` for Wallet V5 R1 and `v4r2` for Wallet V4 R2.
COLLECTION_ADDRESS=
# Leave empty for the first deploy. The script will fill it automatically after successful deploy.
COLLECTION_METADATA_URL=https://example.com/collection.json
ITEMS_BASE_URL=https://example.com/nft/
# Prefix mode: if this ends with `/`, item metadata becomes `ITEMS_BASE_URL + <suffix>`.
# Fixed-file mode: if this points to a concrete file like `https://example.com/nft/176.json`,
# every minted SBT will point to that exact file and ITEM_METADATA_SUFFIX will be ignored.
ITEM_METADATA_SUFFIX=
# Optional. Used only in prefix mode.
# If empty, the CLI uses `0.json`, `1.json`, `2.json`, ... by item index.
# If set, every minted SBT uses this same suffix under ITEMS_BASE_URL.
IS_TESTNET=true
# `true` for testnet, `false` for mainnet.
TONCENTER_API_KEY=
# Optional but recommended.
# Without an API key, Toncenter public hosts are rate-limited.
# Get a key through the official @toncenter bot:
# https://docs.ton.org/ecosystem/api/toncenter/get-api-key
TONCENTER_ENDPOINT=
TONCENTER_RPS_LIMIT=1
TONCENTER_RPS_PERIOD=1.0
SBT_COLLECTION_CODE_BOC=contracts/nft-collection.boc
SBT_ITEM_CODE_BOC=contracts/nft-item-sbt.boc
DEPLOY_AMOUNT_TON=0.05
MINT_MESSAGE_VALUE_TON=0.02
ITEM_FORWARD_AMOUNT_TON=0.005
BATCH_SIZE=50
VERIFY_MINTS=true
SEND_TIMEOUT_SECONDS=90
POLL_INTERVAL_SECONDS=2.0
